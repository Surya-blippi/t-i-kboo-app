# Copy to .env.local (local) and set the same vars in Vercel → Settings → Environment Variables.

# AI (server-side proxy)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxx
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# DodoPayments — one-time unlock
# Test: https://test.dodopayments.com   Live: https://live.dodopayments.com
DODO_API_KEY=your_dodo_api_key
DODO_BASE_URL=https://test.dodopayments.com
DODO_PRODUCT_ID=pdt_xxxxxxxx

# Display-only price label on the paywall
NEXT_PUBLIC_UNLOCK_PRICE=₹149
